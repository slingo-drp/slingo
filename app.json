{
  "expo": {
    "name": "slingo",
    "slug": "slingo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icons/ios/iTunesArtwork@2x.png",
    "scheme": "slingo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.slingo.app",
      "icon": "./assets/app-icons/ios/iTunesArtwork@2x.png",
      "associatedDomains": ["applinks:slingo.app"]
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000a14",
        "foregroundImage": "./assets/app-icons/android/mipmap-xxxhdpi/ic_launcher_foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.slingo.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "slingo.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/app-icons/android/ic_launcher-web.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000a14",
          "android": {
            "image": "./assets/app-icons/android/mipmap-xxxhdpi/ic_launcher_foreground.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Slingo to access your photos so you can choose a profile avatar.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-video",
      "expo-sqlite",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab030e04-2b11-4265-a982-d60a8b6438cd"
      }
    },
    "owner": "slingo-drp"
  }
}
